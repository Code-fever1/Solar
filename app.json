{
  "expo": {
    "name": "GridWise",
    "slug": "Solar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/meter.png",
    "scheme": "solar",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "icon": "./assets/images/meter.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/meter.png",
        "backgroundColor": "#0A0E1A"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.gridwise.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0E1A",
          "image": "./assets/images/meter.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
